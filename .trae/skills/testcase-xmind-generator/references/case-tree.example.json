{
  "project": "账号登录",
  "modules": [
    {
      "name": "登录",
      "scenarios": [
        {
          "name": "使用正确账号密码登录",
          "cases": [
            {
              "title": "用户使用正确用户名和密码登录成功",
              "preconditions": [
                "用户账号存在且为启用状态",
                "登录页面可正常访问"
              ],
              "steps": [
                "打开登录页面",
                "输入正确用户名",
                "输入正确密码",
                "点击登录"
              ],
              "expected": "系统跳转到首页/工作台，登录成功",
              "priority_level": "1",
              "type": "functional",
              "covers": [
                "R-001"
              ]
            }
          ]
        },
        {
          "name": "密码错误登录",
          "cases": [
            {
              "title": "用户输入错误密码登录失败",
              "preconditions": [
                "用户账号存在"
              ],
              "steps": [
                "打开登录页面",
                "输入正确用户名",
                "输入错误密码",
                "点击登录"
              ],
              "expected": "页面提示账号或密码错误，且停留在登录页",
              "priority_level": "2",
              "type": "negative",
              "covers": [
                "R-002"
              ],
              "notes": "关注连续失败次数限制与提示文案一致性"
            }
          ]
        }
      ]
    }
  ]
}
